# Port for the LoopIn API server
PORT=3002

# Public base URL — used to generate reviewUrl links in interrupt responses
LOOPIN_BASE_URL=http://localhost:3002

# Optional API key — if set, all requests must include X-API-Key: <value>
# Review pages (/review/*), /health, and /openapi.json are always public
API_KEY_SECRET=change-me
