{
  "name": "@colossal-api/loopin",
  "version": "1.0.0",
  "description": "Human-in-the-loop interrupt API for AI agents — pause, review, and resume",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
